# settings

(interlaced no)
(compression 9)
(bkgd yes)
(offs yes)
(phys yes)
(time yes)
(save-transparent no)
(optimize-palette no)
(format "auto")
(include-exif yes)
(include-iptc no)
(include-xmp yes)
(include-color-profile yes)
(include-thumbnail no)
(include-comment yes)
(gimp-comment "Created with GIMP")

# end of settings
