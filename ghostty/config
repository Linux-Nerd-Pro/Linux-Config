#theme = Aizen Dark
# ---------------------------------------------------------
# GHOSTTY CONFIGURATION FOR FEDORA i3
# ---------------------------------------------------------

# --- Visuals & Theme ---
#theme = dark:catppuccin-mocha
background-opacity = 0.85
background-blur-radius = 20
font-family = "JetBrains Mono"
font-size = 11
font-feature = "calt"
font-feature = "zero"

# --- Window Decoration ---
# On i3, we usually want the window manager to handle borders.
# 'none' removes Ghostty's custom title bar for a seamless i3 look.
window-decoration = none
window-padding-x = 8
window-padding-y = 8
window-theme = system

# --- Cursor ---
cursor-style = block
cursor-style-blink = true
shell-integration-features = cursor,sudo

# --- Mouse & Interaction ---
mouse-hide-while-typing = true
copy-on-select = clipboard
scrollback-limit = 10000

# --- Performance & Rendering ---
# Ghostty will auto-detect X11 vs Wayland, but you can force it if needed.
# renderer = opengl 

# --- Keybindings (i3-Friendly) ---
# We use 'ctrl+shift' or 'alt' to avoid clashing with the i3 'Super' key.

# Clipboard
keybind = ctrl+shift+c=copy_to_clipboard
keybind = ctrl+shift+v=paste_from_clipboard

# Split Management (Internal to Ghostty)
keybind = alt+e=new_split:right
keybind = alt+o=new_split:down
keybind = alt+h=goto_split:left
keybind = alt+j=goto_split:bottom
keybind = alt+k=goto_split:top
keybind = alt+l=goto_split:right

# Tab Management
keybind = ctrl+shift+t=new_tab
keybind = ctrl+shift+q=close_surface
keybind = ctrl+tab=next_tab
keybind = ctrl+shift+tab=previous_tab

# Quick Terminal (Quake Mode)
# This allows a dropdown terminal even on i3!
#quick-terminal-key = f12
quick-terminal-position = top

# --- Advanced Fedora/Linux Tweaks ---
# Ensure the terminal informs the system it's a modern terminal
#xterm-screen-256color = true
